<Project Sdk="Microsoft.NET.Sdk">

  <!-- Floor-SDK dogfood consumer. Deliberately NOT part of FirstClassErrors.sln: ci.yml would build it
       under the .NET 10 SDK, which proves nothing and only causes confusion. It is built solely by the
       "floor" job in .github/workflows/analyzers.yml, whose nested tools/floor-check/global.json selects
       the .NET 8 (Roslyn 4.8) SDK.

       Unlike a ProjectReference, this project consumes the PACKED FirstClassErrors NuGet package from a
       local feed (see nuget.config). That validates two things at once on the Roslyn floor: (1) the
       analyzer still loads on the oldest supported host — a newer Roslyn reference would fail with CS8032;
       and (2) the analyzer actually ships where consumers expect it (analyzers/dotnet/cs), because a
       broken packaging path would leave the analyzer silently absent and this build green-but-meaningless
       (the "prove the analyzer loaded" step guards against exactly that). -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- An analyzer that fails to load (CS8032) or throws while loading (AD0001) must break the build,
         not merely warn. That failure is the entire signal this project exists to produce. -->
    <WarningsAsErrors>$(WarningsAsErrors);CS8032;AD0001</WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reuse the dogfood sample's sources verbatim (no duplication); skip its own build output. -->
    <Compile Include="../../FirstClassErrors.Usage/**/*.cs"
             Exclude="../../FirstClassErrors.Usage/obj/**/*.cs;../../FirstClassErrors.Usage/bin/**/*.cs" />
    <!-- Consume the packed package, NOT a ProjectReference: this is what a real consumer restores, so the
         analyzer is wired in from the package's analyzers/dotnet/cs folder. The .nupkg is produced into
         ./local-feed by the floor job's `dotnet pack` step; this Version MUST match the -p:Version passed
         to that step in .github/workflows/analyzers.yml. -->
    <PackageReference Include="FirstClassErrors" Version="1.0.0-floorcheck" />
  </ItemGroup>

</Project>
