<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Deterministic sources for the floor check. <clear/> drops any inherited (machine/user/repo)
         source so restore behaves the same on a developer box and on the CI runner. local-feed supplies
         the freshly packed FirstClassErrors package (with its bundled analyzer) that the floor job's
         `dotnet pack` step writes here; the path is resolved relative to THIS file, so it is
         tools/floor-check/local-feed regardless of the CWD. nuget.org must stay: on machines whose SDK
         does not bundle the net8.0 targeting packs, restore downloads Microsoft.NETCore.App.Ref & co. as
         packages (NU1101 without it) — but it is barred from supplying FirstClassErrors by the mapping
         below. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="local-feed" value="./local-feed" />
  </packageSources>
  <packageSourceMapping>
    <!-- Route the FirstClassErrors id EXCLUSIVELY to the local feed. Without this, restore may also ask
         nuget.org for the id, and a package published there under this name could one day be served in
         place of the one this job just packed (the classic substitution/dependency-confusion trap). With
         the mapping, nuget.org structurally cannot supply FirstClassErrors — only the freshly packed
         .nupkg can. Everything else (e.g. the targeting packs above) stays free to come from nuget.org. -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="local-feed">
      <package pattern="FirstClassErrors" />
    </packageSource>
  </packageSourceMapping>
</configuration>
