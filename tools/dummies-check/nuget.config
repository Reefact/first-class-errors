<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Deterministic sources for the compatibility check. <clear/> drops any inherited (machine/user/repo)
         source so restore behaves identically on a developer box and on the CI runner. local-feed supplies the
         freshly packed Dummies package that the workflow's `dotnet pack` step writes here; the path is resolved
         relative to THIS file, so it is tools/dummies-check/local-feed regardless of the CWD. nuget.org must
         stay: building the net6.0/net8.0 targets under the .NET 10 SDK restores the matching targeting packs
         (Microsoft.NETCore.App.Ref & co.) as packages — but nuget.org is barred from supplying Dummies by the
         mapping below. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="local-feed" value="./local-feed" />
  </packageSources>
  <packageSourceMapping>
    <!-- Route the Dummies id EXCLUSIVELY to the local feed. Without this, restore could also ask nuget.org for
         the id, and a package published there under this name could one day be served in place of the one this
         job just packed (the classic substitution / dependency-confusion trap). With the mapping, nuget.org
         structurally cannot supply Dummies — only the freshly packed .nupkg can. Everything else (the targeting
         packs above) stays free to come from nuget.org. -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="local-feed">
      <package pattern="Dummies" />
    </packageSource>
  </packageSourceMapping>
</configuration>
