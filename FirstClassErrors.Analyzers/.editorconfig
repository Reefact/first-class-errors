# Scoped to the analyzer project. Raise the analyzer-development (RS*) rule categories to `warning` so the
# command-line build (and therefore CI) surfaces the same issues an IDE flags. The Localization category is left at
# its defaults on purpose: FirstClassErrors localizes its error catalog, but the analyzer's own diagnostic messages
# do not need to go through .resx.

[*.cs]
dotnet_analyzer_diagnostic.category-MicrosoftCodeAnalysisCorrectness.severity = warning
dotnet_analyzer_diagnostic.category-MicrosoftCodeAnalysisDesign.severity = warning
dotnet_analyzer_diagnostic.category-MicrosoftCodeAnalysisPerformance.severity = warning
dotnet_analyzer_diagnostic.category-MicrosoftCodeAnalysisReleaseTracking.severity = warning
